# Precious Metals Vault AI — Environment Variables
# Copy this to .env and fill in your values

# metals.dev API Key (https://metals.dev)
# Get your free API key at https://metals.dev/dashboard
# Free tier: 1,000 requests/month (~33/day)
# Without this key, spot prices will use fallback/hardcoded values
METALS_API_KEY=your_api_key_here

# Backend port (optional, defaults to 3001)
# BACKEND_PORT=3001
